# Agent configuration
AGENT_NAME=acme-ai-agent
AGENT_VERSION=1.0.0

# Approval gate — webhook endpoint for human approval requests
# In production this would be a real HITL system (PagerDuty, Slack webhook, etc.)
APPROVAL_WEBHOOK_URL=http://localhost:8000/approvals

# Auto-approve read-only actions in dry-run mode (never auto-approve writes)
DRY_RUN=false

# Audit log SQLite path
AUDIT_DB_PATH=data/audit.db

# Tool registry path
TOOL_REGISTRY_PATH=tools/registry.yaml

# Policy rules path
POLICY_RULES_PATH=policy/rules.yaml

# Log level
LOG_LEVEL=INFO

# Maximum tool call depth (prevents infinite loops)
MAX_TOOL_DEPTH=10
